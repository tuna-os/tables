{
    "id": "io.github.hanthor.tables",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "command": "tables",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri"
    ],
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/share/doc",
        "*.la",
        "*.a"
    ],
    "modules": [
        {
            "name": "python3-deps",
            "buildsystem": "simple",
            "build-options": {
                "build-args": [ "--share=network" ]
            },
            "build-commands": [
                "pip3 install --prefix=${FLATPAK_DEST} --no-warn-script-location openpyxl python-calamine odfpy"
            ],
            "comment": "Network build for himachal pipeline; Flathub uses vendored wheels."
        },
        {
            "name": "tables",
            "buildsystem": "simple",
            "build-options": {
                "build-args": [ "--share=network" ]
            },
            "build-commands": [
                "rm -rf subprojects/suite-common _build",
                "git clone --depth 1 https://github.com/hanthor/suite-common.git subprojects/suite-common",
                "meson setup --prefix=${FLATPAK_DEST} --reconfigure _build",
                "ninja -C _build install"
            ],
            "sources": [
                {
                    "type": "dir",
                    "path": "."
                }
            ]
        }
    ]
}
